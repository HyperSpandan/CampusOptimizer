rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (auth.uid)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required, must be @vitbhopal.ac.in)
    //   - displayName: string
    //   - photoURL: string
    //   - role: string (required, 'student' or 'admin')
    //   - createdAt: timestamp
    //
    // Collection: resources
    // Document ID: resourceId
    // Fields:
    //   - name: string (required)
    //   - type: string (required)
    //   - status: string (required)
    //   ...
    //
    // Collection: bookings
    // Document ID: bookingId
    // Fields:
    //   - userId: string (required)
    //   - resourceId: string (required)
    //   - status: string (required)
    //   ...
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isVITDomain() {
      return request.auth.token.email.matches(".*@vitbhopal\\.ac\\.in$");
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (getUserData().role == 'admin' || 
              ((request.auth.token.email.lower() == "dhagespandan@gmail.com" || request.auth.token.email.lower() == "dhage.25bce10259@vitbhopal.ac.in") && isEmailVerified()));
    }

    function isStudent() {
      return isAuthenticated() && getUserData().role == 'student';
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.email == request.auth.token.email &&
             data.role in ['student', 'admin'] &&
             data.email.matches(".*@vitbhopal\\.ac\\.in$");
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isVITDomain() && isValidUser(request.resource.data) && 
                    (request.resource.data.role == 'student' || isAdmin());
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /resources/{resourceId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isVITDomain() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }
  }
}
